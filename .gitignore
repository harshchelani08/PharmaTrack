# =============================================
# PharmaTrack — Global .gitignore
# =============================================

# Node.js / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm

# Build outputs
dist/
build/
out/
.next/
.nuxt/

# Environment & Secrets (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Prisma generated client
backend/node_modules/
backend/dist/

# Go binaries & build artifacts
go-inventory/main
go-inventory/*.exe
go-inventory/tmp/

# IDE & Editor
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
logs/
*.log
*.log.*

# Test coverage
coverage/
*.lcov
.nyc_output

# Docker volumes (local)
pgdata/
redisdata/

# TypeScript compiled output
*.js.map
*.d.ts.map

# Vite cache
.vite/
frontend/.vite/

# Prisma migration lock (keep migrations, not the lock file in dev)
# prisma/migrations - keep this tracked

# OS artifacts
.DS_Store
Desktop.ini
