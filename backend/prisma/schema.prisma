datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleType {
  SUPER_ADMIN
  CHAIN_OWNER
  BRANCH_MANAGER
  PHARMACIST
  CASHIER
}

enum SubscriptionPlan {
  FREE_TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum POStatus {
  PENDING
  APPROVED
  REJECTED
  RECEIVED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  SHIPPED
  DELIVERED
  REJECTED
}

enum PaymentMode {
  CASH
  CARD
  UPI
  MIXED
}

model Tenant {
  id            String         @id @default(uuid())
  name          String
  subdomain     String         @unique
  logoUrl       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  
  users         User[]
  branches      Branch[]
  drugs         Drug[]
  suppliers     Supplier[]
  subscriptions Subscription[]
  invoices      Invoice[]
  
  @@index([subdomain])
}

model User {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          RoleType       @default(CASHIER)
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  
  sales         Sale[]
  auditLogs     AuditLog[]
  
  @@index([tenantId])
  @@index([email])
}

model Branch {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  code          String         @unique
  address       String
  phone         String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  
  users         User[]
  batches       Batch[]
  incomingTransfers Transfer[] @relation("IncomingTransfers")
  outgoingTransfers Transfer[] @relation("OutgoingTransfers")
  sales         Sale[]
  purchaseOrders PurchaseOrder[]
  
  @@index([tenantId])
}

model Drug {
  id                  String         @id @default(uuid())
  tenantId            String
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brandName           String
  genericName         String
  category            String
  hsnCode             String
  dosageForm          String
  manufacturer        String
  unit                String
  barcode             String         @unique
  prescriptionRequired Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?
  
  batches             Batch[]
  transferItems       TransferItem[]
  saleItems           SaleItem[]
  poItems             PurchaseOrderItem[]
  
  @@index([tenantId])
  @@index([barcode])
  @@index([brandName, genericName])
}

model Batch {
  id            String         @id @default(uuid())
  tenantId      String
  branchId      String
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  drugId        String
  drug          Drug           @relation(fields: [drugId], references: [id], onDelete: Cascade)
  batchNumber   String
  expiryDate    DateTime
  quantity      Int
  purchasePrice Decimal        @db.Decimal(10, 2)
  sellingPrice  Decimal        @db.Decimal(10, 2)
  supplierId    String?
  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  inventoryLogs InventoryLog[]
  saleItems     SaleItem[]
  
  @@index([tenantId])
  @@index([branchId])
  @@index([drugId])
  @@index([expiryDate])
}

model InventoryLog {
  id            String         @id @default(uuid())
  tenantId      String
  batchId       String
  batch         Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  changeQty     Int
  prevQty       Int
  newQty        Int
  reason        String
  userId        String?
  createdAt     DateTime       @default(now())
  
  @@index([tenantId])
  @@index([batchId])
}

model Supplier {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  contactName   String?
  phone         String
  email         String?
  gstin         String?
  address       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  
  batches       Batch[]
  purchaseOrders PurchaseOrder[]
  
  @@index([tenantId])
}

model PurchaseOrder {
  id            String         @id @default(uuid())
  tenantId      String
  branchId      String
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  status        POStatus       @default(PENDING)
  totalAmount   Decimal        @db.Decimal(10, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  items         PurchaseOrderItem[]
  
  @@index([tenantId])
  @@index([branchId])
}

model PurchaseOrderItem {
  id              String         @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  drugId          String
  drug            Drug           @relation(fields: [drugId], references: [id], onDelete: Cascade)
  quantityOrdered Int
  quantityReceived Int           @default(0)
  unitPrice       Decimal        @db.Decimal(10, 2)
  
  @@index([purchaseOrderId])
}

model Sale {
  id                  String         @id @default(uuid())
  tenantId            String
  branchId            String
  branch              Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber       String         @unique
  subtotal            Decimal        @db.Decimal(10, 2)
  taxAmount           Decimal        @db.Decimal(10, 2)
  totalAmount         Decimal        @db.Decimal(10, 2)
  paymentMode         PaymentMode    @default(CASH)
  prescriptionId      String?
  prescription        Prescription?  @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  createdAt           DateTime       @default(now())
  
  saleItems           SaleItem[]
  invoices            Invoice[]
  
  @@index([tenantId])
  @@index([branchId])
  @@index([invoiceNumber])
}

model SaleItem {
  id            String         @id @default(uuid())
  saleId        String
  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  drugId        String
  drug          Drug           @relation(fields: [drugId], references: [id], onDelete: Cascade)
  batchId       String
  batch         Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  quantity      Int
  unitPrice     Decimal        @db.Decimal(10, 2)
  taxPercentage Decimal        @db.Decimal(5, 2)
  totalPrice    Decimal        @db.Decimal(10, 2)
  
  @@index([saleId])
}

model Transfer {
  id              String         @id @default(uuid())
  tenantId        String
  fromBranchId    String
  fromBranch      Branch         @relation("OutgoingTransfers", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranchId      String
  toBranch        Branch         @relation("IncomingTransfers", fields: [toBranchId], references: [id], onDelete: Cascade)
  status          TransferStatus @default(REQUESTED)
  remarks         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  items           TransferItem[]
  
  @@index([tenantId])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model TransferItem {
  id            String         @id @default(uuid())
  transferId    String
  transfer      Transfer       @relation(fields: [transferId], references: [id], onDelete: Cascade)
  drugId        String
  drug          Drug           @relation(fields: [drugId], references: [id], onDelete: Cascade)
  quantity      Int
  
  @@index([transferId])
}

model Prescription {
  id            String         @id @default(uuid())
  tenantId      String
  patientName   String
  doctorName    String
  doctorLicense String
  prescriptionDate DateTime
  imageUrl      String?
  notes         String?
  createdAt     DateTime       @default(now())
  
  sales         Sale[]
  
  @@index([tenantId])
}

model Alert {
  id            String         @id @default(uuid())
  tenantId      String
  branchId      String?
  type          String
  message       String
  isRead        Boolean        @default(false)
  createdAt     DateTime       @default(now())
  
  @@index([tenantId])
  @@index([branchId])
}

model Subscription {
  id            String             @id @default(uuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeCustId  String
  stripeSubId   String             @unique
  plan          SubscriptionPlan   @default(STARTER)
  status        SubscriptionStatus @default(TRIALING)
  currentPeriodEnd DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  
  @@index([tenantId])
}

model Invoice {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleId        String
  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  pdfUrl        String?
  createdAt     DateTime       @default(now())
  
  @@index([tenantId])
}

model AuditLog {
  id            String         @id @default(uuid())
  tenantId      String
  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String
  details       String
  ipAddress     String?
  createdAt     DateTime       @default(now())
  
  @@index([tenantId])
}
